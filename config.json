{
   "directorios": {
      "pug": {
         "fuente": [
            "html/**/*.pug",
            "!html/layout/*.pug",
            "!html/components/*.pug"
         ],
         "destino": {
            "dev": "distribution/dev/html",
            "prod": "distribution/prod/html"
         },
         "watcher": "html/**/*.pug",
         "recargar": {
            "dev": "distribution/dev/**.html",
            "prod": "distribution/prod/**.html"
         }
      }
   }
}